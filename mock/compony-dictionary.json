    "articles": [
        {
            "id": "제1조",
            "title": "목적",
            "content": "본 지침은 외부감사 대상 법인 및 중견기업에 대한 거액 여신 심사 시, 차주의 상환 능력과 담보 안정성을 객관적으로 평가하고 부실 채권 발생을 사전에 방지하기 위한 심사 기준 및 필수 서류 징구 절차를 규정함을 목적으로 한다."
        },
        {
            "id": "제2조",
            "title": "적용 대상 및 심사 전결 권한",
            "rules": [
                {
                    "rule_id": "2-1",
                    "name": "본부 여신심사위원회 부의 대상",
                    "condition": "단일 기업 신규 신청 금액 > 50억원 OR 총여신 노출액 > 100억원",
                    "action": "영업점장 전결 권한 배제, 본부 여신심사위원회 심의 필수"
                },
                {
                    "rule_id": "2-2",
                    "name": "대출 과목",
                    "content": "기업일반자금대출(시설 및 운전) 원칙. 무역금융(수입신용장 개설 및 유산스 대환) 포함 복합 여신 구조 시 본 지침 준용"
                }
            ]
        },
        {
            "id": "제3조",
            "title": "신용등급 및 업종별 취급 제한",
            "rules": [
                {
                    "rule_id": "3-1",
                    "name": "정밀 신용등급 제한",
                    "threshold": "BBB-",
                    "condition": "내부신용등급 < BBB- (즉, BB+ 이하)",
                    "action": "거액 신규 여신 취급 제한",
