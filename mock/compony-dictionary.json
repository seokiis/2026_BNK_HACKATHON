                    "covenant_id": "5-2",
                    "name": "이자보상배율 제한",
                    "formula": "영업이익 / 금융비용(이자)",
                    "threshold_min": 1.5,
                    "unit": "배",
                    "condition": "최소 1.50배 이상",
                    "critical_threshold": 1.0,
                    "critical_action": "이자보상배율 1.0배 미만 = 이자불보상기업, 원칙적 여신 취급 금지"
                }
            ],
            "exception_clause": {
                "name": "맥락적 근거 보완 조항",
                "condition": "부채비율이 내규 임계치 초과 BUT 최근 1년 매출액 및 연도별 매출자료상 성장세가 뚜렷하게 입증",
                "action": "상환 재원의 정당성 인정, 정성적 참작 가능",
                "required_evidence": [
                    "최근 전방 산업 동향",
                    "기술적 특수성",
                    "매출 성장세 입증"
                ]
            }
        },
        {
            "id": "제6조",
            "title": "상업용 담보 부동산의 경매 통계 연동 규칙",
            "rules": [
                {
                    "rule_id": "6-1",
                    "name": "지역 낙찰가율 연동 차감",
                    "condition": "담보 소재 행정구역의 최근 1년간 평균 낙찰가율 < 75%",
                    "threshold": 0.75,
                    "action": "내규 담보인정비율(LTV) 기준에서 10%p 강제 차감 적용",
                    "penalty_pct": 10
                },
                {
                    "rule_id": "6-2",
                    "name": "통계적 표본 신뢰도 제한",
                    "condition": "해당 지역 최근 1년간 경매 낙찰건수 < 5건",
                    "threshold": 5,
                    "action": "영업점 독단 담보가치 인정 불가",
                    "additional_requirement": "인근 유사 행정구역의 매매 회전율 및 공실률 동향을 심사보고서에 추가 정밀 서술 제출"
                }
            ]
        }
    ],
    "decision_logic_summary": {
