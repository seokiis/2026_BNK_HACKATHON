                    "restricted_grade_list": [
                        "BB+",
                        "BB",
                        "BB-",
                        "B+",
                        "B",
                        "B-",
                        "CCC",
                        "CC",
                        "C",
                        "D"
                    ]
                },
                {
                    "rule_id": "3-2",
                    "name": "CSS 신용평점 준용",
                    "condition": "대표이사 개인 연대보증 입보 또는 소규모 자회사 여신 심사 시",
                    "action": "보조 지표로만 활용 (원칙적 제외)"
                },
                {
                    "rule_id": "3-3",
                    "name": "업종 및 공시 필터링",
                    "conditions": [
